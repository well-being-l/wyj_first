<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kmbeast.mapper.FeedPointMapper">

    <insert id="insert" parameterType="cn.kmbeast.pojo.entity.FeedPoint" useGeneratedKeys="true" keyProperty="feedId">
        INSERT INTO feed_point (feed_name,
                                feed_location,
                                feed_status,
                                feed_remark)
        VALUES (#{feedName},
                #{feedLocation},
                #{feedStatus},
                #{feedRemark})
    </insert>

    <update id="update" parameterType="cn.kmbeast.pojo.entity.FeedPoint">
        UPDATE feed_point
        <set>
            <if test="feedName != null">
                feed_name = #{feedName},
            </if>
            <if test="feedLocation != null">
                feed_location = #{feedLocation},
            </if>
            <if test="feedStatus != null">
                feed_status = #{feedStatus},
            </if>
            <if test="feedRemark != null">
                feed_remark = #{feedRemark},
            </if>
        </set>
        WHERE feed_id = #{feedId}
    </update>

    <delete id="batchDelete" parameterType="list">
        DELETE FROM feed_point WHERE feed_id IN
        <foreach collection="ids" item="feedId" open="(" separator="," close=")">
            #{feedId}
        </foreach>
    </delete>

    <select id="getById" resultType="cn.kmbeast.pojo.entity.FeedPoint">
        SELECT * FROM feed_point WHERE feed_id = #{feedId}
    </select>

    <select id="query" resultType="cn.kmbeast.pojo.entity.FeedPoint">
        SELECT * FROM feed_point
        <where>
            <if test="feedName != null and feedName != ''">
                AND feed_name LIKE concat('%', #{feedName}, '%')
            </if>
            <if test="feedStatus != null and feedStatus != ''">
                AND feed_status = #{feedStatus}
            </if>
        </where>
        ORDER BY feed_id DESC
        <if test="current != null and size != null">
            LIMIT #{current}, #{size}
        </if>
    </select>

    <select id="queryCount" resultType="integer">
        SELECT COUNT(*) FROM feed_point
        <where>
            <if test="feedName != null and feedName != ''">
                AND feed_name LIKE concat('%', #{feedName}, '%')
            </if>
            <if test="feedStatus != null and feedStatus != ''">
                AND feed_status = #{feedStatus}
            </if>
        </where>
    </select>

</mapper>