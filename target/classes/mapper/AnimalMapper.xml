<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kmbeast.mapper.AnimalMapper">

    <!-- 结果映射 -->
    <resultMap id="AnimalResultMap" type="cn.kmbeast.pojo.entity.Animal">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="type" property="type"/>
        <result column="avatar" property="avatar"/>
        <result column="location" property="location"/>
        <result column="age" property="age"/>
        <result column="gender" property="gender"/>
        <result column="color" property="color"/>
        <result column="personality" property="personality"/>
        <result column="description" property="description"/>
        <result column="health_status" property="healthStatus"/>
        <result column="life_status" property="lifeStatus"/>
        <result column="found_time" property="foundTime"/>
        <result column="submitter_id" property="submitterId"/>
        <result column="submitter_name" property="submitterName"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <!-- VO结果映射 -->
    <resultMap id="AnimalVOResultMap" type="cn.kmbeast.pojo.vo.AnimalVO">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="type" property="type"/>
        <result column="avatar" property="avatar"/>
        <result column="location" property="location"/>
        <result column="age" property="age"/>
        <result column="gender" property="gender"/>
        <result column="color" property="color"/>
        <result column="personality" property="personality"/>
        <result column="description" property="description"/>
        <result column="health_status" property="healthStatus"/>
        <result column="life_status" property="lifeStatus"/>
        <result column="found_time" property="foundTime"/>
        <result column="submitter_id" property="submitterId"/>
        <result column="submitter_name" property="submitterName"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 新增动物 -->
    <insert id="insert" parameterType="cn.kmbeast.pojo.entity.Animal" 
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO animal (
            name, type, avatar, location, age, gender, color,
            personality, description, health_status, life_status,
            found_time, submitter_id, submitter_name
        ) VALUES (
            #{name}, #{type}, #{avatar}, #{location}, #{age}, #{gender}, #{color},
            #{personality}, #{description}, #{healthStatus}, #{lifeStatus},
            #{foundTime}, #{submitterId}, #{submitterName}
        )
    </insert>

    <!-- 更新动物 -->
    <update id="update" parameterType="cn.kmbeast.pojo.entity.Animal">
        UPDATE animal SET
            name = #{name},
            type = #{type},
            avatar = #{avatar},
            location = #{location},
            age = #{age},
            gender = #{gender},
            color = #{color},
            personality = #{personality},
            description = #{description},
            health_status = #{healthStatus},
            life_status = #{lifeStatus},
            found_time = #{foundTime},
            submitter_id = #{submitterId},
            submitter_name = #{submitterName}
        WHERE id = #{id} AND is_deleted = 0
    </update>

    <!-- 批量删除动物 -->
    <update id="batchDelete">
        UPDATE animal SET is_deleted = 1
        WHERE id IN 
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- 根据ID查询 -->
    <select id="getById" parameterType="integer" resultMap="AnimalResultMap">
        SELECT * FROM animal 
        WHERE id = #{id} AND is_deleted = 0
    </select>

    <!-- 查询动物列表 -->
    <select id="query" parameterType="cn.kmbeast.pojo.dto.query.extend.AnimalQueryDto" 
            resultMap="AnimalVOResultMap">
        SELECT * FROM animal 
        WHERE is_deleted = 0
        <if test="queryDto.name != null and queryDto.name != ''">
            AND name LIKE CONCAT('%', #{queryDto.name}, '%')
        </if>
        <if test="queryDto.type != null and queryDto.type != ''">
            AND type = #{queryDto.type}
        </if>
        <if test="queryDto.location != null and queryDto.location != ''">
            AND location LIKE CONCAT('%', #{queryDto.location}, '%')
        </if>
        <if test="queryDto.lifeStatus != null and queryDto.lifeStatus != ''">
            AND life_status = #{queryDto.lifeStatus}
        </if>
        <if test="queryDto.healthStatus != null">
            AND health_status = #{queryDto.healthStatus}
        </if>
        <if test="queryDto.gender != null and queryDto.gender != ''">
            AND gender = #{queryDto.gender}
        </if>
        <if test="queryDto.color != null and queryDto.color != ''">
            AND color LIKE CONCAT('%', #{queryDto.color}, '%')
        </if>
        <if test="queryDto.submitterId != null">
            AND submitter_id = #{queryDto.submitterId}
        </if>
        <if test="queryDto.submitterName != null and queryDto.submitterName != ''">
            AND submitter_name LIKE CONCAT('%', #{queryDto.submitterName}, '%')
        </if>
        ORDER BY create_time DESC
        <if test="queryDto.pageNum != null and queryDto.pageSize != null">
            LIMIT #{queryDto.pageSize} OFFSET #{queryDto.pageNum} * #{queryDto.pageSize} - #{queryDto.pageSize}
        </if>
    </select>

    <!-- 查询动物总数 -->
    <select id="queryCount" parameterType="cn.kmbeast.pojo.dto.query.extend.AnimalQueryDto" 
            resultType="integer">
        SELECT COUNT(*) FROM animal 
        WHERE is_deleted = 0
        <if test="queryDto.name != null and queryDto.name != ''">
            AND name LIKE CONCAT('%', #{queryDto.name}, '%')
        </if>
        <if test="queryDto.type != null and queryDto.type != ''">
            AND type = #{queryDto.type}
        </if>
        <if test="queryDto.location != null and queryDto.location != ''">
            AND location LIKE CONCAT('%', #{queryDto.location}, '%')
        </if>
        <if test="queryDto.lifeStatus != null and queryDto.lifeStatus != ''">
            AND life_status = #{queryDto.lifeStatus}
        </if>
        <if test="queryDto.healthStatus != null">
            AND health_status = #{queryDto.healthStatus}
        </if>
        <if test="queryDto.gender != null and queryDto.gender != ''">
            AND gender = #{queryDto.gender}
        </if>
        <if test="queryDto.color != null and queryDto.color != ''">
            AND color LIKE CONCAT('%', #{queryDto.color}, '%')
        </if>
        <if test="queryDto.submitterId != null">
            AND submitter_id = #{queryDto.submitterId}
        </if>
        <if test="queryDto.submitterName != null and queryDto.submitterName != ''">
            AND submitter_name LIKE CONCAT('%', #{queryDto.submitterName}, '%')
        </if>
    </select>

    <!-- 统计各类型数量 -->
    <select id="countByType" resultType="map">
        SELECT type, COUNT(*) as count 
        FROM animal 
        WHERE is_deleted = 0
        GROUP BY type
    </select>

    <!-- 统计各状态数量 -->
    <select id="countByLifeStatus" resultType="map">
        SELECT life_status, COUNT(*) as count 
        FROM animal 
        WHERE is_deleted = 0
        GROUP BY life_status
    </select>

</mapper>