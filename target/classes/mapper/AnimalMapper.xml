<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kmbeast.mapper.AnimalMapper">

    <insert id="insert" parameterType="cn.kmbeast.pojo.entity.Animal" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO animal (name,
                            gender,
                            age,
                            type,
                            personality,
                            health_status,
                            found_time,
                            submitter_id,
                            location,
                            image,
                            remark)
        VALUES (#{name},
                #{gender},
                #{age},
                #{type},
                #{personality},
                #{healthStatus},
                #{foundTime},
                #{submitterId},
                #{location},
                #{image},
                #{remark})
    </insert>

    <update id="update" parameterType="cn.kmbeast.pojo.entity.Animal">
        UPDATE animal
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="gender != null">
                gender = #{gender},
            </if>
            <if test="age != null">
                age = #{age},
            </if>
            <if test="type != null">
                type = #{type},
            </if>
            <if test="personality != null">
                personality = #{personality},
            </if>
            <if test="healthStatus != null">
                health_status = #{healthStatus},
            </if>
            <if test="location != null">
                location = #{location},
            </if>
            <if test="image != null">
                image = #{image},
            </if>
            <if test="remark != null">
                remark = #{remark},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="batchDelete" parameterType="list">
        DELETE FROM animal WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="getById" resultType="cn.kmbeast.pojo.entity.Animal">
        SELECT * FROM animal WHERE id = #{id}
    </select>

    <select id="query" resultType="cn.kmbeast.pojo.vo.AnimalVO">
        SELECT a.*, u.username as submitterName
        FROM animal a
        LEFT JOIN user u ON a.submitter_id = u.id
        <where>
            <if test="name != null and name != ''">
                AND a.name LIKE concat('%', #{name}, '%')
            </if>
            <if test="gender != null and gender != ''">
                AND a.gender = #{gender}
            </if>
            <if test="type != null and type != ''">
                AND a.type = #{type}
            </if>
            <if test="healthStatus != null">
                AND a.health_status = #{healthStatus}
            </if>
            <if test="submitterId != null">
                AND a.submitter_id = #{submitterId}
            </if>
        </where>
        ORDER BY a.found_time DESC
        <if test="current != null and size != null">
            LIMIT #{current}, #{size}
        </if>
    </select>

    <select id="queryCount" resultType="integer">
        SELECT COUNT(*)
        FROM animal a
        <where>
            <if test="name != null and name != ''">
                AND a.name LIKE concat('%', #{name}, '%')
            </if>
            <if test="gender != null and gender != ''">
                AND a.gender = #{gender}
            </if>
            <if test="type != null and type != ''">
                AND a.type = #{type}
            </if>
            <if test="healthStatus != null">
                AND a.health_status = #{healthStatus}
            </if>
            <if test="submitterId != null">
                AND a.submitter_id = #{submitterId}
            </if>
        </where>
    </select>

</mapper>

